{
  "manifest_version": 3,
  "name": "KithKit Chrome Connect",
  "version": "1.0.0",
  "description": "Connect Chrome to a KithKit agent for shared browser sessions",
  "permissions": ["debugger", "activeTab", "storage", "tabs", "alarms", "offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
