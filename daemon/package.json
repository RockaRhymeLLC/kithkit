{
  "name": "@kithkit/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Kithkit daemon — HTTP API, SQLite state, agent lifecycle, message routing.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp -r src/core/migrations dist/core/",
    "start": "node dist/main.js",
    "dev": "tsc --watch",
    "test": "node --test --test-concurrency=1 dist/__tests__/*.test.js dist/__tests__/integration/*.test.js",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^12.6.2",
    "cc4me-network": "file:../../cc4me-network/packages/sdk",
    "cron-parser": "^5.5.0",
    "js-yaml": "^4.1.1",
    "kithkit-a2a-client": "file:../.a2a-sdk/packages/sdk",
    "sqlite-vec": "^0.1.7-alpha.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "minimatch": "^10.2.4"
  }
}
